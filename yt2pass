def parse_arguments(options: Options) -> None:
    """
    Parse command-line arguments.

    Args:
        options: Options object to store parsed arguments. Contains:
            - my_name:                         Name of the program.
            - log_mode:                        Logging mode (default is logging.INFO).
            - args:                            Parsed arguments will be stored here.
            - langs:                           List of requested subtitle language bases.
            - nosubs:                          Whether to skip the subtitles pass entirely.
            - onlysubs:                        Whether to only do the subtitles pass.
            - auto:                            Whether to allow auto-generated captions.
            - strict:                          Whether to treat all requested languages as hard requirements.
            - cooldown_between_passes_secs:    Seconds to wait between subtitle and media passes.
            - cooldown_between_sub_tries_secs: Seconds to wait between subtitle retries.
            - max_tries:                       Maximum subtitle attempts before failing.
            - rate_limit_kbps:                 Download rate limit in kB/s (0 = no limit).
            - aria:                            Whether to use aria2c as external downloader.

    Returns:
        None

    Raises:
        SystemExit: For -h/--help and -v/--version.
    """

    # ---- pre-parse: handle early-exit flags without requiring positionals ----
    pre = argparse.ArgumentParser(add_help=False)
    pre.add_argument("--print-langs", action="store_true")
    pre_args, remaining = pre.parse_known_args()

    if pre_args.print_langs:
        # keep this tiny and side-effect-free
        for code, name in sorted(_LANG_TITLES.items()):
            print(f"  {code}: {name}")
        print("orig: original language (if detectable). This is a special code that may map to different languages per video.")
        sys.exit(0)

    # ---- full parser (normal behavior) ----
    parser = argparse.ArgumentParser(
        description=f"Strict two-pass yt-dlp wrapper. {options.my_name} version {__version__}"
    )
    parser.add_argument("-v", "--version", action="version",
                        version=f"%(prog)s {__version__}")
    parser.add_argument("-d", "--debug", action="store_true",
                        help="Enable debug logging.")
    parser.add_argument("--langs", default=",".join(options.langs),
                        help=f"Required subtitle language bases (default: {','.join(options.langs)}). Human-made subs only by default; add --auto to allow auto captions. EXAMPLE: yt2pass --langs en,fr,ko 'https://youtu.be/VIDEOID'")
    parser.add_argument("--print-langs", action="store_true",
                        help="Print available language codes and names, then exit.")
    parser.add_argument("--cooldown-between-passes", type=int, default=options.cooldown_between_passes_secs,
                        help=f"Seconds to sleep between subtitle pass and media pass (default: {options.cooldown_between_passes_secs})")
    parser.add_argument("--cooldown-between-tries", type=int, default=options.cooldown_between_sub_tries_secs,
                        help=f"Seconds to sleep between subtitle retries (default: {options.cooldown_between_sub_tries_secs})")
    parser.add_argument("--max-tries", type=int, default=options.max_tries,
                        help=f"Maximum subtitle attempts before failing hard (default: {options.max_tries})")
    parser.add_argument("--rate-limit", type=int, default=options.rate_limit_kbps,
                        help=f"Limit download rate in kB/s (default: {options.rate_limit_kbps}.)"
                              "0 = no limit. Applies to media/subtitle downloads, not metadata probes.")
    parser.add_argument("--nosubs", action="store_true", default=options.nosubs,
                        help=f"Skip the subtitles pass entirely (still embeds any existing .srt files. default: {options.nosubs}).")
    parser.add_argument("--onlysubs", action="store_true", default=options.onlysubs,
                        help=f"Download/check subtitles only, then exit (skip media pass. default: {options.onlysubs}).")
    parser.add_argument("--auto", action="store_true", default=options.auto,
                        help=f"Also allow auto-generated captions if human-made subs are not available. (default: {options.auto}).")
    parser.add_argument("--strict", action="store_true", default=options.strict_mode_default,
                        help=("Treat *all* requested subtitle languages as hard requirements "
                              "(including auto-translated ones). On HTTP 429, use very long "
                              "exponential backoff and fail the run if any requested language "
                              "is still missing after max-tries."))
    parser.add_argument("--720p", dest="prefer_720p",
                        action="store_true", default=options.prefer_720p,
                        help="Prefer 720p video when choosing formats (if available).")
    parser.add_argument("--smallest", dest="prefer_smallest",
                        action="store_true", default=options.prefer_smallest,
                        help="Prefer the smallest available video resolution (lowest height).")
    parser.add_argument("--go-low", action="store_true", default=options.go_low,
                        help=("Allow downloads when the site only exposes the low-quality "
                              "'mp4-low' video format. Without this flag, yt2pass treats "
                              "mp4-low-only availability as a transient error and retries "
                              "after a long cooldown."))
    parser.add_argument("--po-token", default=os.getenv("YT_PO_TOKEN"),
                        help="Advanced: YouTube PO token in the form CLIENT.CONTEXT+TOKEN. "
                             "If set, used during the subtitles pass to request missing auto captions.")
    parser.add_argument("--aria", action="store_true", default=False,
                        help="Use aria2c as an external downloader for improved performance.")
    parser.add_argument("url", nargs="?",
                        help="Video/playlist URL (omit to just check yt-dlp and exit)")
    parser.add_argument("extra", nargs=argparse.REMAINDER, default=[],
                        help="Extra args to forward to yt-dlp (rarely needed)")
    options.args = parser.parse_args(remaining)  # use remaining from pre-parse
    langs_raw              = options.args.langs
    options.args.langs     = [s.strip().lower() for s in langs_raw.split(",") if s.strip()]
    options.args.max_tries = max(1, options.args.max_tries)
    if options.args.debug:
        options.log_mode = logging.DEBUG
    if options.args.strict and not options.args.auto:
        print("--strict used without --auto: only human-made subtitles are considered; "
              "--strict will just make HTTP 429 handling more patient.")
    if options.args.onlysubs and options.args.nosubs:
        raise ValueError("Cannot use both --onlysubs and --nosubs together.")
    if options.args.prefer_720p and options.args.prefer_smallest:
        raise SystemExit("Cannot use --720p and --smallest together.")


def main() -> None:
    """
    Main function.

    Args:
        None

    Returns:
        None
    """
    options = Options()

    parse_arguments(options)
    assert options.args is not None  # For mypy
    logging.basicConfig(level=options.log_mode,
                        format="%(asctime)s - %(levelname)s - %(message)s",
                        datefmt="%Y-%m-%d %H:%M:%S")

    _ensure_ytdlp_available()
    _validate_filename_pattern(options)
    _start_cancel_key_listener()
    _ensure_aria_if_requested(options)

    if not _ffmpeg_available():
        logging.warning("ffmpeg not found on PATH. Subtitles may remain as .vtt/.ass; "
                        "conversion to .srt (requested via --convert-subs srt) will be skipped.")

    _check_ytdlp_version(options)

    if not options.args.url:
        logging.info("No URL provided; exiting after yt-dlp check.")
        sys.exit(0)

    url:         str = options.args.url
    extra: list[str] = options.args.extra

    mode = "onlysubs" if options.args.onlysubs else ("nosubs" if options.args.nosubs else "normal")
    logging.info("Starting yt2pass: url=%s | langs=%s | mode=%s",
                 url, " ".join(options.args.langs), mode)
    # Fast probe to determine if this is a playlist
    try:
        info = _probe_info(options, url)
    except Exception as e:
        logging.error("Failed to probe URL: %s", e)
        sys.exit(3)

    is_playlist = (info.get("_type") == "playlist") or bool(info.get("entries"))

    if not is_playlist:  # Single video – do the normal two-pass flow
        rc = _process_single(options, url, extra, prefix=None, info=info)
        if rc != 0:
            sys.exit(rc)
    else:                # Playlist – iterate entries
        entries = [e for e in (info.get("entries") or []) if e]
        n = len(entries)
        if n == 0:
            logging.error("Playlist has no entries.")
            sys.exit(3)

        width = len(str(n))
        logging.info("Detected playlist with %d items.", n)

        failed_items: list[tuple[int, str, int]] = []

        # Process each entry individually
        for i, entry in enumerate(entries, start=1):
            item_url = _entry_url(entry)
            if not item_url:
                logging.warning("Skipping entry %d: no usable URL.", i)
                continue

            prefix = f"{i:0{width+1}d} - "  # Add an extra zero so the playlist can expand if necessary

            # Playlist resume: best-effort guess of the title base from the
            # shallow entry metadata so we can cheaply skip items whose media
            # was already downloaded in a previous run.
            title_hint = _title_base_from_metadata(options, entry, prefix=prefix)
            if _have_media_for_title_base(title_hint):
                logging.info("Skipping item %d/%d: media file already exists for %s "
                             "(playlist resume).", i, n, title_hint or "<unknown>")
                continue

            # Fallback: match any media file by video ID alone
            # (covers renamed / annotated files).
            entry_vid = _sanitize_filename_component((entry.get("id") or "").strip())
            id_hit    = _find_media_by_video_id(entry_vid) if entry_vid else None
            if id_hit:
                logging.info("Skipping item %d/%d: found existing media by video ID %s: %s "
                             "(filename was modified since download).",
                             i, n, entry_vid, id_hit.name)
                if title_hint:
                    _symlink_media_alias(title_hint, id_hit)
                continue

            logging.info("Processing item %d/%d: %s", i, n, item_url)
            # Do not pass pre-probed info down to _process_single(); playlist
            # entries are shallow and often lack formats/subtitles.

            rc = _process_single(options, item_url, extra, prefix=prefix, info=None)
            if rc != 0:
                logging.error(
                    "Item %d/%d FAILED with rc=%d; skipping this item and continuing.",
                    i, n, rc)
                failed_items.append((i, item_url, rc))
                continue

        if failed_items:
            logging.warning("Playlist completed with %d failed item(s):", len(failed_items))
            for idx, item_url, rc in failed_items:
                logging.warning("  #%d (rc=%d): %s", idx, rc, item_url)
        else:
            logging.info("Playlist completed successfully.")

    logging.info("Done.")

    logging.shutdown()


def _validate_filename_pattern(options: Options) -> None:
    """
    Validate the user-supplied filename pattern by attempting to format it.

    Args:
        options: Options object containing the filename pattern.

    Returns:
        None

    Raises:
        SystemExit: If the filename pattern is invalid.
    """
    try:
        # dry-run with dummy values
        options.filename_pattern % {"uploader": "u",
                                    "title"   : "t",
                                    "id"      : "id"}
    except KeyError as e:
        raise SystemExit(f"Invalid filename pattern (unknown placeholder {e!r})") from e
    except Exception as e:
        raise SystemExit(f"Invalid filename pattern: {e}") from e


def _base_args(options: Options, *, fast: bool = False) -> list[str]:
    """
    Shared yt-dlp args.
    fast=True  -> omit sleeps/long retries and any rate limiting (for probes).
    fast=False -> include normal sleeps/retries; respect --rate-limit if set.
    """
    args = ["--cookies-from-browser", "firefox",
            "--no-overwrites",
            "--audio-multistreams",
            "--merge-output-format", "mkv",
            "-o", options.output_template(),
            "--concurrent-fragments", "1"]
    if not fast:
        # General retry tuning
        div = max(1, options.ytdlp_extractor_retry_divisor)
        args += ["--retries", str(options.args.max_tries),
                 "--retry-sleep", options.ytdlp_retry_sleep,
                 "--extractor-retries",
                 str(max(options.ytdlp_min_extractor_retries,
                         options.args.max_tries // div))]
        # Apply user rate limit if provided (kB/s -> "NNNK")
        if options.args and getattr(options.args, "rate_limit", 0):
            k = int(options.args.rate_limit)
            if k > 0:
                args += ["--limit-rate", f"{k}K"]
    # If requested, prefer aria2c for external downloading
    if options.args and getattr(options.args, "aria", False):
        args += ["--external-downloader", "aria2c",
                 "--external-downloader-args", "aria2c:-x 16 -k 1M"]
    return args


def _subs_args(options: Options, sub_langs_arg: str) -> list[str]:
    """Arguments for yt-dlp that are specific to the subtitles pass."""
    div = max(1, options.ytdlp_extractor_retry_divisor)
    args = [
        "--skip-download",
        "--write-subs",
        "--convert-subs", "srt",
        "--sleep-requests", str(options.subs_sleep_requests_secs),
        "--retries", str(options.args.max_tries),
        "--retry-sleep", options.subs_retry_sleep,
        "--extractor-retries",
        str(max(options.subs_min_extractor_retries,
                options.args.max_tries // div)),
        "--concurrent-fragments", "1",
        "--sub-langs", sub_langs_arg,
    ]
    # If --auto was supplied, request auto-captions too
    if getattr(options.args, "auto", False):
        args.append("--write-auto-subs")
    # If a valid PO token was supplied, merge it with the player_client so we
    # don't clobber extractor-args from _base_args(). Last occurrence wins.
    po = getattr(options.args, "po_token", None)
    if po:
        args += ["--extractor-args", f"youtube:player_client=tv_embedded;po_token={po}"]
    return args


def _media_args(options: Options) -> list[str]:
    """Arguments for yt-dlp that are specific to the media pass."""
    # Use a high but finite number of fragment retries so we don't hang forever
    # on permanent 404s. Tie it loosely to max_tries but clamp to a sane range.
    max_tries    = getattr(options.args, "max_tries", 10) if options.args else 10
    frag_retries = max(options.frag_retries_min,
                       min(options.frag_retries_max, max_tries))
    return [
        "--no-write-subs",
        "--no-write-auto-subs",
        "--embed-subs",                # always embed subs if present on disk (even with --nosubs)
        "--fragment-retries", str(frag_retries),
        "--file-access-retries", str(max_tries),
    ]


def _os_name() -> str:
    """Return a simple OS name: 'Windows' | 'macOS' | 'Linux' | '<Other>'."""
    s = platform.system()
    if s == "Darwin":
        return "macOS"
    if s in ("Linux", "Windows"):
        return s
