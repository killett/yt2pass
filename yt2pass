class Options:
    """Class that has all global options in one place."""

    def __init__(self) -> None:
        """Initialize the Options class with default values."""
        self.my_name:                         str = Path(sys.argv[0]).stem

        self.nosubs:                         bool = bool(0)  # Set to True (1) to skip subtitle pass
        self.onlysubs:                       bool = bool(0)  # Set to True (1) to ONLY subtitle pass
        self.auto:                           bool = bool(0)  # Set to True (1) to allow auto-captions
        self.strict_mode_default:            bool = bool(0)  # Default for --strict flag
        self.langs:                     list[str] = ["en", "fr", "orig"]  #, "es", "de", "ko", "zh"

        # Resolution preferences (CLI flags)
        self.prefer_720p:                    bool = bool(0)
        self.prefer_smallest:                bool = bool(0)
        self.go_low:                         bool = bool(0)  # Allow mp4-low-only fallback

        # Per-language maximum attempts for subtitles/media.
        # Strict-mode backoff might further cap the *effective* tries for repeated HTTP 429s.
        self.max_tries:                       int =   5
        self.cooldown_between_passes_secs:    int =  90
        self.cooldown_between_sub_tries_secs: int = 180
        self.rate_limit_kbps:                 int =   0  # 0 = no limit

        # Base filename pattern, *without* extension. Used everywhere.
        self.filename_pattern:                str = "%(title)s - %(uploader)s - ID %(id)s"

        # Strict-mode backoff tuning
        self.strict_sleep_base:               int =     3600  # minimum base cooldown (seconds)
        self.strict_max_sleep:                int = 8 * 3600  # per-attempt cap for strict backoff (seconds)
        self.strict_exp_base:                 int =        4  # exponential factor for strict backoff

        # Sleep/backoff tuning (used by _sleep_with_countdown)
        self.sleep_jitter_percent:          float =    0.12   # ± jitter for sleeps
        self.sleep_min_secs:                  int =       5   # minimum sleep duration
        self.sleep_log_step_secs:             int =    3600   # default step between countdown logs

        # Probe / retry tuning
        self.probe_max_outer:                 int =       5   # max outer probe attempts before failing
        self.probe_retry_cooldown_secs:       int =       3   # base cooldown between probe attempts

        # yt-dlp retry tuning for general (non-subs) calls
        self.ytdlp_retry_sleep:               str = "15:45"   # base args retry sleep ("min:max")
        self.ytdlp_min_extractor_retries:     int =      10   # floor for extractor retries in base args
        self.ytdlp_extractor_retry_divisor:   int =       3   # divisor to derive extractor retries

        # Subtitle-specific retry tuning
        self.subs_sleep_requests_secs:        int =      20   # sleep between HTTP requests during subs pass
        self.subs_retry_sleep:                str = "60:120"  # subtitle downloads retry sleep ("min:max")
        self.subs_min_extractor_retries:      int =      20   # floor for extractor retries during subs pass

        # Media fragment retry tuning
        self.frag_retries_min:                int =       5   # transient 404s - try a few times
        self.frag_retries_max:                int =      50   # permanent 404s - don't retry indefinitely

        # Non-strict 429 handling (subtitles/media)
        self.non_strict_429_factor:           int =       3   # multiplier of cooldown_between_tries
        self.non_strict_429_min_sleep:        int =    1200   # minimum backoff on 429 in non-strict mode

        # Auto-update tuning
        self.update_stamp_age_secs:           int = 24 * 3600  # minimum time between auto-update attempts

        self.log_mode:                        int = logging.INFO
        self.args:      argparse.Namespace | None = None
        if self.onlysubs and self.nosubs:
            raise ValueError("Cannot use both options.onlysubs and options.nosubs together.")

    @property
    def strict_base_cooldown(self) -> int:
        """
        Effective base cooldown for strict-mode backoff: never shorter than either
        strict_sleep_base or the user-configured --cooldown-between-tries.
        ONLY CALL THIS AFTER parse_arguments HAS RUN AND POPULATED options.args!
        """
        return max(int(getattr(self.args, "cooldown_between_tries", 0) or 0),
                   self.strict_sleep_base)

    def output_template(self, prefix: str | None = None) -> str:
        """
        Full yt-dlp -o template including extension placeholder, optionally
        prefixed (e.g., '003-').

        Args:
            prefix: Optional string to prefix the filename pattern with.
        
        Returns:
            Full output template string for yt-dlp.
        """
        base = self.filename_pattern
        if prefix:
            base = f"{prefix}{base}"
        return f"{base}.%(ext)s"


